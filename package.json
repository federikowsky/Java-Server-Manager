{
  "name": "java-server-manager",
  "displayName": "Java Server Manager",
  "description": "A simple, modern alternative to RSP UI for managing Java servers (Tomcat, Jetty, and more) inside VSCode.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.100.0"
  },
  "type": "commonjs",
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jsm.server.add",
        "title": "Add Server",
        "icon": "$(add)"
      },
      {
        "command": "jsm.templates.manage",
        "title": "Manage Templates",
        "icon": "$(settings-gear)"
      },
      {
        "command": "jsm.server.startRun",
        "title": "Start (Run)",
        "icon": "$(play)"
      },
      {
        "command": "jsm.server.startDebug",
        "title": "Start (Debug)",
        "icon": "$(debug-alt)"
      },
      {
        "command": "jsm.server.stop",
        "title": "Stop Server",
        "icon": "$(stop)"
      },
      {
        "command": "jsm.server.restartRun",
        "title": "Restart (Run)",
        "icon": "$(refresh)"
      },
      {
        "command": "jsm.server.restartDebug",
        "title": "Restart (Debug)",
        "icon": "$(debug-rerun)"
      },
      {
        "command": "jsm.server.edit",
        "title": "Edit Server",
        "icon": "$(edit)"
      },
      {
        "command": "jsm.server.deployChanges",
        "title": "Deploy Changes",
        "icon": "$(sync)"
      },
      {
        "command": "jsm.server.fullRedeploy",
        "title": "Full Redeploy",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "jsm.server.viewLogs",
        "title": "View Logs",
        "icon": "$(output)"
      },
      {
        "command": "jsm.server.delete",
        "title": "Delete Server",
        "icon": "$(trash)"
      },
      {
        "command": "jsm.server.openDir",
        "title": "Open Server Directory",
        "icon": "$(folder-opened)"
      },
      {
        "command": "jsm.server.copyInfo",
        "title": "Copy Server Info",
        "icon": "$(copy)"
      },
      {
        "command": "jsm.deployment.add",
        "title": "Add Deployment",
        "icon": "$(file-add)"
      },
      {
        "command": "jsm.deployment.edit",
        "title": "Edit Deployment",
        "icon": "$(edit)"
      },
      {
        "command": "jsm.deployment.remove",
        "title": "Remove Deployment",
        "icon": "$(trash)"
      },
      {
        "command": "jsm.deployment.forceDeploy",
        "title": "Force Deploy",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "jsm.deployment.undeploySoft",
        "title": "Undeploy",
        "icon": "$(cloud-download)"
      },
      {
        "command": "jsm.deployment.toggleAutosync",
        "title": "Toggle AutoSync",
        "icon": "$(sync)"
      },
      {
        "command": "jsm.treeview.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "jsm.deployment.removeSoft",
        "title": "Remove Deployment (Config Only)",
        "icon": "$(trash)"
      },
      {
        "command": "jsm.deployment.removeHard",
        "title": "Remove Deployment (And Files)",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "jsm.server.add",
          "when": "view == javaServerManagerView",
          "group": "navigation@1"
        },
        {
          "command": "jsm.treeview.refresh",
          "when": "view == javaServerManagerView",
          "group": "navigation@2"
        },
        {
          "command": "jsm.templates.manage",
          "when": "view == javaServerManagerView",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "jsm.server.startRun",
          "when": "view == javaServerManagerView && viewItem == server-stopped",
          "group": "inline@1"
        },
        {
          "command": "jsm.server.startDebug",
          "when": "view == javaServerManagerView && viewItem == server-stopped",
          "group": "inline@2"
        },
        {
          "command": "jsm.server.stop",
          "when": "view == javaServerManagerView && viewItem == server-running",
          "group": "inline@1"
        },
        {
          "command": "jsm.server.restartRun",
          "when": "view == javaServerManagerView && viewItem == server-running",
          "group": "inline@2"
        },
        {
          "command": "jsm.server.restartDebug",
          "when": "view == javaServerManagerView && viewItem == server-running",
          "group": "inline@3"
        },
        {
          "command": "jsm.server.stop",
          "when": "view == javaServerManagerView && viewItem == server-starting",
          "group": "inline@1"
        },
        {
          "command": "jsm.server.stop",
          "when": "view == javaServerManagerView && viewItem == server-stopping",
          "group": "inline@1"
        },
        {
          "command": "jsm.server.startRun",
          "when": "view == javaServerManagerView && viewItem == server-error",
          "group": "inline@1"
        },
        {
          "command": "jsm.server.startDebug",
          "when": "view == javaServerManagerView && viewItem == server-error",
          "group": "inline@2"
        },
        {
          "command": "jsm.server.edit",
          "when": "view == javaServerManagerView && viewItem =~ /server-.*/",
          "group": "2_manage@1"
        },
        {
          "command": "jsm.server.deployChanges",
          "when": "view == javaServerManagerView && viewItem =~ /server-.*/",
          "group": "2_manage@2"
        },
        {
          "command": "jsm.server.fullRedeploy",
          "when": "view == javaServerManagerView && viewItem =~ /server-.*/",
          "group": "2_manage@3"
        },
        {
          "command": "jsm.server.viewLogs",
          "when": "view == javaServerManagerView && viewItem =~ /server-.*/",
          "group": "2_manage@4"
        },
        {
          "command": "jsm.server.openDir",
          "when": "view == javaServerManagerView && viewItem =~ /server-.*/",
          "group": "2_manage@5"
        },
        {
          "command": "jsm.server.copyInfo",
          "when": "view == javaServerManagerView && viewItem =~ /server-.*/",
          "group": "2_manage@6"
        },
        {
          "command": "jsm.deployment.add",
          "when": "view == javaServerManagerView && viewItem =~ /server-.*/",
          "group": "3_deployments@1"
        },
        {
          "command": "jsm.server.delete",
          "when": "view == javaServerManagerView && viewItem =~ /server-.*/",
          "group": "9_danger@1"
        },
        {
          "command": "jsm.deployment.forceDeploy",
          "when": "view == javaServerManagerView && viewItem == deployment",
          "group": "inline@1"
        },
        {
          "command": "jsm.deployment.undeploySoft",
          "when": "view == javaServerManagerView && viewItem == deployment",
          "group": "inline@2"
        },
        {
          "command": "jsm.deployment.toggleAutosync",
          "when": "view == javaServerManagerView && viewItem == deployment",
          "group": "1_manage@1"
        },
        {
          "command": "jsm.deployment.edit",
          "when": "view == javaServerManagerView && viewItem == deployment",
          "group": "1_manage@2"
        },
        {
          "command": "jsm.deployment.remove",
          "when": "view == javaServerManagerView && viewItem == deployment",
          "group": "9_danger@1"
        },
        {
          "command": "jsm.deployment.removeSoft",
          "when": "view == javaServerManagerView && viewItem == deployment",
          "group": "9_danger@2"
        },
        {
          "command": "jsm.deployment.removeHard",
          "when": "view == javaServerManagerView && viewItem == deployment",
          "group": "9_danger@3"
        }
      ]
    },
    "views": {
      "javaServerManager": [
        {
          "id": "javaServerManagerView",
          "name": "Java Servers",
          "when": "workspaceFolderCount > 0"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "javaServerManager",
          "title": "Java Server Manager",
          "icon": "$(server)"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out --skipLibCheck",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit --skipLibCheck",
    "lint": "eslint src",
    "test": "node out/src/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/lodash.debounce": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/sinon": "^17.0.4",
    "@types/vscode": "^1.100.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "esbuild": "^0.25.3",
    "eslint": "^9.25.1",
    "glob": "^11.0.2",
    "mocha": "^11.5.0",
    "npm-run-all": "^4.1.5",
    "sinon": "^20.0.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.1"
  },
  "dependencies": {
    "lodash.debounce": "^4.0.8",
    "uuid": "^11.1.0"
  }
}
