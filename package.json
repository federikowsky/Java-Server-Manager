{
  "name": "java-server-manager",
  "displayName": "Java Server Manager",
  "description": "A simple, modern alternative to RSP UI for managing Java servers (Tomcat, Jetty, and more) inside VSCode.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.100.0"
  },
  "type": "commonjs",
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jsm.server.add",
        "title": "Add Server",
        "icon": "$(add)"
      },
      {
        "command": "jsm.templates.manage",
        "title": "Manage Templates",
        "icon": "$(settings-gear)"
      },
      {
        "command": "jsm.server.startRun",
        "title": "Start (Run)",
        "icon": "$(play)"
      },
      {
        "command": "jsm.server.startDebug",
        "title": "Start (Debug)",
        "icon": "$(debug-alt)"
      },
      {
        "command": "jsm.server.stop",
        "title": "Stop Server",
        "icon": "$(stop)"
      },
      {
        "command": "jsm.server.restartRun",
        "title": "Restart (Run)",
        "icon": "$(refresh)"
      },
      {
        "command": "jsm.server.restartDebug",
        "title": "Restart (Debug)",
        "icon": "$(debug-rerun)"
      },
      {
        "command": "jsm.server.edit",
        "title": "Edit Server",
        "icon": "$(edit)"
      },
      {
        "command": "jsm.server.syncAllDeployments",
        "title": "Sync All Deployments",
        "icon": "$(sync)"
      },
      {
        "command": "jsm.server.fullRedeployAll",
        "title": "Full Redeploy All",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "jsm.server.openLogs",
        "title": "Open Logs",
        "icon": "$(file)"
      },
      {
        "command": "jsm.server.remove",
        "title": "Remove Server",
        "icon": "$(trash)"
      },
      {
        "command": "jsm.diagnostics.copy",
        "title": "Copy Diagnostics",
        "icon": "$(copy)"
      },
      {
        "command": "jsm.deployment.add",
        "title": "Add Deployment",
        "icon": "$(file-add)"
      },
      {
        "command": "jsm.deployment.edit",
        "title": "Edit Deployment",
        "icon": "$(edit)"
      },
      {
        "command": "jsm.deployment.remove",
        "title": "Remove Deployment",
        "icon": "$(trash)"
      },
      {
        "command": "jsm.deployment.sync",
        "title": "Sync",
        "icon": "$(sync)"
      },
      {
        "command": "jsm.deployment.fullRedeploy",
        "title": "Full Redeploy",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "jsm.deployment.undeploy",
        "title": "Undeploy",
        "icon": "$(cloud-download)"
      },
      {
        "command": "jsm.deployment.toggleAutosync",
        "title": "Toggle AutoSync",
        "icon": "$(sync)"
      },
      {
        "command": "jsm.view.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "jsm.server.add",
          "when": "view == javaServerManagerView",
          "group": "navigation@1"
        },
        {
          "command": "jsm.view.refresh",
          "when": "view == javaServerManagerView",
          "group": "navigation@2"
        },
        {
          "command": "jsm.templates.manage",
          "when": "view == javaServerManagerView",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "jsm.server.startRun",
          "when": "view == javaServerManagerView && viewItem == jsm.server.stopped",
          "group": "inline@1"
        },
        {
          "command": "jsm.server.startDebug",
          "when": "view == javaServerManagerView && viewItem == jsm.server.stopped",
          "group": "inline@2"
        },
        {
          "command": "jsm.server.stop",
          "when": "view == javaServerManagerView && viewItem == jsm.server.running",
          "group": "inline@1"
        },
        {
          "command": "jsm.server.restartRun",
          "when": "view == javaServerManagerView && viewItem == jsm.server.running",
          "group": "inline@2"
        },
        {
          "command": "jsm.server.restartDebug",
          "when": "view == javaServerManagerView && viewItem == jsm.server.running",
          "group": "inline@3"
        },
        {

          "command": "jsm.server.startRun",
          "when": "view == javaServerManagerView && viewItem == jsm.server.error",
          "group": "inline@1"
        },
        {
          "command": "jsm.server.startDebug",
          "when": "view == javaServerManagerView && viewItem == jsm.server.error",
          "group": "inline@2"
        },
        {
          "command": "jsm.server.syncAllDeployments",
          "when": "view == javaServerManagerView && viewItem =~ /jsm\\.server\\..*/",
          "group": "deploy@1"
        },
        {
          "command": "jsm.server.fullRedeployAll",
          "when": "view == javaServerManagerView && viewItem =~ /jsm\\.server\\..*/",
          "group": "deploy@2"
        },
        {          "command": "jsm.deployment.add",
          "when": "view == javaServerManagerView && viewItem =~ /jsm\\.server\\..*/",
          "group": "deploy@3"
        },
        {          "command": "jsm.server.edit",
          "when": "view == javaServerManagerView && viewItem =~ /jsm\\.server\\..*/",
          "group": "manage@1"
        },
        {
          "command": "jsm.server.remove",
          "when": "view == javaServerManagerView && viewItem =~ /jsm\\.server\\..*/",
          "group": "manage@2"
        },
        {

          "command": "jsm.server.openLogs",
          "when": "view == javaServerManagerView && viewItem =~ /jsm\\.server\\..*/",
          "group": "troubleshooting@1"
        },
        {

          "command": "jsm.diagnostics.copy",
          "when": "view == javaServerManagerView && viewItem =~ /jsm\\.server\\..*/",
          "group": "troubleshooting@3"
        },
        {
          "command": "jsm.deployment.sync",
          "when": "view == javaServerManagerView && viewItem =~ /jsm\\.deployment\\..*/",
          "group": "inline@1"
        },

        {

          "command": "jsm.deployment.fullRedeploy",
          "when": "view == javaServerManagerView && viewItem =~ /jsm\\.deployment\\..*/",
          "group": "actions@2"
        },
        {
          "command": "jsm.deployment.undeploy",
          "when": "view == javaServerManagerView && viewItem =~ /jsm\\.deployment\\..*/",
          "group": "actions@3"
        },
        {
          "command": "jsm.deployment.toggleAutosync",
          "when": "view == javaServerManagerView && viewItem =~ /jsm\\.deployment\\..*/",
          "group": "autosync@1"
        },
        {
          "command": "jsm.deployment.edit",
          "when": "view == javaServerManagerView && viewItem =~ /jsm\\.deployment\\..*/",
          "group": "manage@1"
        },
        {
          "command": "jsm.deployment.remove",
          "when": "view == javaServerManagerView && viewItem =~ /jsm\\.deployment\\..*/",
          "group": "manage@2"
        }
      ]
    },
    "views": {
      "javaServerManager": [
        {
          "id": "javaServerManagerView",
          "name": "Java Servers",
          "when": "workspaceFolderCount >= 0"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "javaServerManager",
          "title": "Java Server Manager",
          "icon": "$(server)"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p tsconfig.test.json --skipLibCheck",
    "watch-tests": "tsc -p tsconfig.test.json -w --skipLibCheck",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit --skipLibCheck",
    "lint": "eslint src",
    "test": "node out/src/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/lodash.debounce": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/sinon": "^17.0.4",
    "@types/vscode": "^1.100.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "esbuild": "^0.25.3",
    "eslint": "^9.25.1",
    "glob": "^11.0.2",
    "mocha": "^11.5.0",
    "npm-run-all": "^4.1.5",
    "sinon": "^20.0.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.1"
  },
  "dependencies": {
    "lodash.debounce": "^4.0.8",
    "uuid": "^11.1.0"
  }
}
